# LaTeX build output
paper/main.pdf
paper2-gas-pockets/main.pdf
paper3-scaling-laws/main.pdf
projects/**/paper/main.pdf

# Draft snapshots (regenerable from source — do not commit)
**/drafts/*.pdf

# Keep cover letters and graphical abstract (small, non-regenerable)
!paper/cover-letter.pdf
!paper/graphical-abstract.pdf
!paper2-gas-pockets/cover-letter.pdf

# Generated figures (regenerable via scripts/generate_figures.py)
data/figures/*.pdf
data/figures/*.png
paper2-gas-pockets/figures/*.pdf
paper2-gas-pockets/figures/*.png
paper3-scaling-laws/figures/*.pdf
projects/**/figures/*.pdf
projects/**/figures/*.png

