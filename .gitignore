data/results/**/*.h5
data/results/**/*.vtu
data/results/**/*.vtk
data/results/**/*.pvd
data/results/**/*.msh
*.xdmf
*.h5

# Keep directory structure
!data/results/.gitkeep
!data/materials/*.json

