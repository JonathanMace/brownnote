# Git LFS tracking for large simulation files
*.h5 filter=lfs diff=lfs merge=lfs -text
*.xdmf filter=lfs diff=lfs merge=lfs -text
*.vtu filter=lfs diff=lfs merge=lfs -text
*.vtk filter=lfs diff=lfs merge=lfs -text
*.pvd filter=lfs diff=lfs merge=lfs -text
*.msh filter=lfs diff=lfs merge=lfs -text
*.stl filter=lfs diff=lfs merge=lfs -text

# Ensure consistent line endings for source files
*.py text eol=lf
*.tex text eol=lf
*.bib text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.json text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.pdf binary
*.eps binary

# Notebooks are text (for diff)
*.ipynb text eol=lf
